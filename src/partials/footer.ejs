<footer style="background: <%= site.branding.colors.black %>; border-top: 1px solid rgba(255,255,255,0.08); padding: 56px 60px; display: grid; grid-template-columns: 200px 1fr 1fr auto; gap: 48px; align-items: start;">
  <div style="display: flex; flex-direction: column; gap: 8px;">
    <div style="font-size: 14px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--white);">
      <%= site.name %>
    </div>
    <div style="font-size: 12px; color: rgba(255,255,255,0.3); letter-spacing: 0.06em;">
      <%= site.tagline %>
    </div>
  </div>
  
  <ul style="display: flex; flex-direction: column; gap: 10px; list-style: none;">
    <% site.navigation.secondary.forEach(link => { %>
      <li>
        <a href="<%= link.href %>" style="color: rgba(255,255,255,0.4); text-decoration: none; font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s;">
          <%= link.label %>
        </a>
      </li>
    <% }); %>
  </ul>
  
  <div style="color: rgba(255,255,255,0.35); font-size: 15px; line-height: 1.8;">
    <p><%= site.email %></p>
    <p><a href="https://wa.me/<%= site.whatsapp %>" style="color: rgba(255,255,255,0.4); text-decoration: none;">WhatsApp: <%= site.whatsapp %></a></p>
  </div>
  
  <div style="display: flex; flex-direction: column; gap: 14px;">
    <a href="<%= site.domain %>" style="display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.35); text-decoration: none; font-size: 14px; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s;">
      boomhaus.design
    </a>
  </div>
</footer>
